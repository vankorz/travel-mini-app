# Токен бота из @BotFather
BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz

# ID группы менеджеров (включая -100 для супергрупп)
MANAGER_CHAT_ID=-1001234567890

# Порт сервера (опционально, по умолчанию 3000)
PORT=3000

# Origin фронтенда для CORS (опционально, по умолчанию *)
# WEBAPP_ORIGIN=https://yourdomain.com

# Проверять подпись Telegram WebApp initData.
# Для локального теста в обычном браузере можно поставить false.
REQUIRE_TELEGRAM_AUTH=true

# Максимальный возраст initData в секундах
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
